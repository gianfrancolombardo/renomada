      "id": "dd100000-0003-4000-8000-000000000003",
      "name": "RPC get_daily_digest_recipients_merged",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const cfg = $('Workflow config').first().json;\n\n/**\n * Supabase REST + n8n HTTP Request often emit either:\n * - one item whose json is the full array [...], or\n * - one item per row (each json is { user_id, ... }).\n * Treating only Array.isArray(first.json) misses the second case.\n */\nfunction normalizeRecipientRows(items) {\n  if (!items.length) return [];\n  const first = items[0].json;\n  if (Array.isArray(first)) return first;\n  if (first && typeof first === 'object' && Array.isArray(first.data)) return first.data;\n  const allObjects = items.every(\n    (i) => i.json && typeof i.json === 'object' && !Array.isArray(i.json),\n  );\n  if (allObjects) return items.map((i) => i.json);\n  return [];\n}\n\nconst rows = normalizeRecipientRows($input.all());\nif (rows.length === 0) {\n  return [{ json: { skip: true, reason: 'no_recipients' } }];\n}\n\nconst seen = new Set();\nconst userIds = [];\nfor (const r of rows) {\n  const id = r && r.user_id;\n  if (!id || seen.has(id)) continue;\n  seen.add(id);\n  userIds.push(String(id));\n}\nif (userIds.length === 0) {\n  return [{ json: { skip: true, reason: 'no_user_ids' } }];\n}\n\nconst body = {\n  app_id: cfg.onesignal_app_id,\n  include_external_user_ids: userIds,\n  headings: { en: cfg.notification_title ?? 'ReNomada' },\n  contents: { en: cfg.notification_body ?? 'You have new activity.' },\n  data: { route: '/feed' },\n};\nreturn [{ json: { skip: false, onesignal_body: body } }];"
      },
