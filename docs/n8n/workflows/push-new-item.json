    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const cfg = $('Workflow config').first().json;\nconst root = $input.first().json;\nconst rows = Array.isArray(root) ? root : [];\nif (rows.length === 0) return [];\nreturn rows.map((r) => ({\n  json: {\n    user_id: r.user_id,\n    device_token: r.token,\n    platform: r.platform,\n    firebase_project_id: cfg.firebase_project_id,\n  },\n}));"
      },
